{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "noImplicitReturns": true,
        "removeComments": true,
        "esModuleInterop": true,
        "noUnusedLocals": true,
        "moduleResolution": "node16",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": "src",
        "paths": {
            "@domain/*": [
                "domain/*"
            ],
            "@infraestructure/*": [
                "infraestructure/*"
            ],
            "@data/*": [
                "data/*"
            ],
            "@api/*": [
                "api/*"
            ],
            "@config/*": [
                "config/*"
            ]
        }
    },
    "compileOnSave": true,
    "include": [
        "src/**/*.ts"
    ]
}